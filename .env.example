# =============================================================
# LLM Provider — chọn "nvidia" hoặc "deepseek"
# =============================================================
LLM_PROVIDER=nvidia

# NVIDIA NIM (dùng khi LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=nvapi-your-api-key-here
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct

# DeepSeek (dùng khi LLM_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=sk-your-api-key-here
# DEEPSEEK_MODEL=deepseek-chat

# =============================================================
# LLM Generation
# =============================================================
LLM_MAX_TOKENS=6144
LLM_TIMEOUT=120
LLM_RETRIES=3
LLM_TEMPERATURE=0
AGENT_PARSE_RETRIES=2

# =============================================================
# Terraform / Pipeline
# =============================================================
TF_PLAN_TIMEOUT=120

# Đường dẫn tới checkov nếu không có trong PATH
# CHECKOV_BIN=C:\path\to\checkov.exe
